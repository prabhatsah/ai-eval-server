// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Difficulty {
  easy
  medium
  hard
}

enum Role {
  MANAGER
  CANDIDATE
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  refreshToken String?

  attempts Attempt[]
}

//////////////////////////////////////////////////////
// EVALUATION
//////////////////////////////////////////////////////
model Evaluation {
  id        String   @id @default(uuid())
  title     String
  skill     String
  config    Json
  createdBy String
  createdAt DateTime @default(now())

  attempts Attempt[]
}

//////////////////////////////////////////////////////
// ATTEMPT
//////////////////////////////////////////////////////
model Attempt {
  id           String @id @default(uuid())
  userId       String
  evaluationId String
  status       String

  mcqScore    Float?
  codingScore Float?
  aiScore     Float?
  finalScore  Float?

  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  user       User       @relation(fields: [userId], references: [id])
  evaluation Evaluation @relation(fields: [evaluationId], references: [id])

  responses Response[]
}


model Response {
  id        String @id @default(uuid())
  attemptId String

  question String
  answer   String
  score    Float?
  feedback String?
  type     String

  attempt Attempt @relation(fields: [attemptId], references: [id])
}

//////////////////////////////////////////////////////
// JOB DESCRIPTION (VERSIONED)
//////////////////////////////////////////////////////

model JobDescription {
  id              String   @id @default(uuid())

  // Logical grouping (same JD across versions)
  jdGroupId       String

  // Versioning
  version         Int

  // Raw input
  rawText         String

  // Parsed structured data
  role            String
  primarySkills   Json
  secondarySkills Json?
  experienceYears Int?
  difficulty      Difficulty
  focusAreas      Json?

  isLatest        Boolean   @default(true) // ✅ quick access

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // RELATION
  assessments     Assessment[]

  @@index([jdGroupId])
  @@index([isLatest])
  @@unique([jdGroupId, version]) // prevents duplicate versions
}

//////////////////////////////////////////////////////
// ASSESSMENT (SNAPSHOT OF JD VERSION)
//////////////////////////////////////////////////////

model Assessment {
  id               String   @id @default(uuid())

  jobDescriptionId String
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id])

  // SNAPSHOT (IMPORTANT)
  role            String
  difficulty      Difficulty
  experienceYears Int?

  mcqCount        Int
  codingCount     Int

  primarySkills   Json
  secondarySkills Json?
  focusAreas      Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // RELATIONS
  mcqs            McqQuestion[]
  codingQuestions CodingQuestion[]

  @@index([role])
  @@index([difficulty])
}

//////////////////////////////////////////////////////
// MCQ QUESTIONS
//////////////////////////////////////////////////////

model McqQuestion {
  id            String   @id @default(uuid())

  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id])

  question      String
  skill         String?

  options       Json
  correctAnswer String

  difficulty    Difficulty
  explanation   String?

  createdAt     DateTime @default(now())

  @@index([assessmentId])
  @@index([skill])
}

//////////////////////////////////////////////////////
// CODING QUESTIONS
//////////////////////////////////////////////////////

model CodingQuestion {
  id            String   @id @default(uuid())

  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id])

  title         String
  problem       String
  constraints   String?

  sampleInput   String?
  sampleOutput  String?
  expectedApproach String?

  difficulty    Difficulty

  createdAt     DateTime @default(now())

  @@index([assessmentId])
}

