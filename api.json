{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/auth/signup": {
      "post": {
        "operationId": "AuthController_signup",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully registered"
          },
          "400": {
            "description": "Invalid input data"
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "summary": "Login user and return JWT token",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
    "/evaluations": {
      "post": {
        "operationId": "EvaluationController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEvaluationDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evaluation created successfully"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create a new evaluation (Manager only)",
        "tags": [
          "Evaluations"
        ]
      },
      "get": {
        "operationId": "EvaluationController_getAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of evaluations"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get all evaluations",
        "tags": [
          "Evaluations"
        ]
      }
    },
    "/evaluations/{id}": {
      "get": {
        "operationId": "EvaluationController_getById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "example": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Evaluation found"
          },
          "404": {
            "description": "Evaluation not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get evaluation by ID",
        "tags": [
          "Evaluations"
        ]
      }
    },
    "/attempt/start": {
      "post": {
        "operationId": "AttemptController_start",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAttemptDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attempt started successfully"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Start a new attempt",
        "tags": [
          "Attempts"
        ]
      }
    },
    "/attempt/answer": {
      "post": {
        "operationId": "AttemptController_submit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitAnswerDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Answer submitted successfully"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Submit answer for a question",
        "tags": [
          "Attempts"
        ]
      }
    },
    "/attempt/submit": {
      "post": {
        "operationId": "AttemptController_finalize",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Attempt submitted successfully"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Finalize attempt and calculate score",
        "tags": [
          "Attempts"
        ]
      }
    },
    "/ai/generate-assessment": {
      "post": {
        "operationId": "AiController_generateAssessment",
        "parameters": [
          {
            "name": "x-gemini-api-key",
            "required": false,
            "in": "header",
            "description": "Gemini API Key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateAssessmentDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assessment generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateAssessmentResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Error response structure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Generate MCQ and coding assessment questions",
        "tags": [
          "Assessment"
        ]
      }
    },
    "/ai/interview": {
      "post": {
        "operationId": "AiController_processInterview",
        "parameters": [
          {
            "name": "x-gemini-api-key",
            "required": false,
            "in": "header",
            "description": "Gemini API Key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProcessInterviewDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Interview evaluation and next question generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessInterviewResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Error response structure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Process interview answer and generate next question",
        "tags": [
          "Assessment"
        ]
      }
    }
  },
  "info": {
    "title": "AI Evaluation API",
    "description": "API documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "test@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123"
          },
          "role": {
            "type": "string",
            "enum": [
              "MANAGER",
              "EMPLOYEE"
            ],
            "example": "MANAGER"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "role"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "test@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SectionConfigDto": {
        "type": "object",
        "properties": {
          "weight": {
            "type": "number",
            "example": 0.5,
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "weight"
        ]
      },
      "SectionsDto": {
        "type": "object",
        "properties": {
          "AI": {
            "$ref": "#/components/schemas/SectionConfigDto"
          },
          "MCQ": {
            "$ref": "#/components/schemas/SectionConfigDto"
          },
          "CODING": {
            "$ref": "#/components/schemas/SectionConfigDto"
          }
        },
        "required": [
          "AI",
          "MCQ",
          "CODING"
        ]
      },
      "CreateEvaluationDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Frontend Assessment"
          },
          "skill": {
            "type": "string",
            "example": "React"
          },
          "sections": {
            "$ref": "#/components/schemas/SectionsDto"
          },
          "passingScore": {
            "type": "number",
            "example": 60,
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": [
          "title",
          "skill",
          "sections",
          "passingScore"
        ]
      },
      "StartAttemptDto": {
        "type": "object",
        "properties": {
          "evaluationId": {
            "type": "string",
            "example": "evaluation-uuid"
          }
        },
        "required": [
          "evaluationId"
        ]
      },
      "SubmitAnswerDto": {
        "type": "object",
        "properties": {
          "attemptId": {
            "type": "string",
            "example": "attempt-uuid"
          },
          "question": {
            "type": "string",
            "example": "What is closure in JavaScript?"
          },
          "answer": {
            "type": "string",
            "example": "A closure is a function with preserved scope..."
          },
          "type": {
            "type": "string",
            "enum": [
              "MCQ",
              "CODING",
              "AI"
            ],
            "example": "AI"
          }
        },
        "required": [
          "attemptId",
          "question",
          "answer",
          "type"
        ]
      },
      "GenerateAssessmentDto": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "example": "Node",
            "description": "Technology or topic for the assessment"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the assessment"
          },
          "mcqCount": {
            "type": "number",
            "example": 1,
            "description": "Number of MCQ questions to generate"
          },
          "codingCount": {
            "type": "number",
            "example": 1,
            "description": "Number of coding questions to generate"
          }
        },
        "required": [
          "topic",
          "difficulty",
          "mcqCount",
          "codingCount"
        ]
      },
      "McqDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "Which of the following is a correct way to import a module in Node.js?",
            "description": "MCQ question"
          },
          "options": {
            "example": [
              "A) require('module-name');",
              "B) import 'module-name';",
              "C) include 'module-name';",
              "D) use 'module-name';"
            ],
            "description": "Available answer options",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correctAnswer": {
            "type": "string",
            "example": "A",
            "description": "Correct answer option"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the MCQ"
          },
          "explanation": {
            "type": "string",
            "example": "In Node.js, the `require` function is used to load and return the exports of a module. The other options are not valid syntax for importing modules in Node.js.",
            "description": "Explanation of the correct answer"
          }
        },
        "required": [
          "question",
          "options",
          "correctAnswer",
          "difficulty",
          "explanation"
        ]
      },
      "CodingQuestionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "File Reader",
            "description": "Title of the coding problem"
          },
          "problem": {
            "type": "string",
            "example": "Write a Node.js program that reads a file from disk, counts the number of lines, and prints the total line count to the console. The path to the file will be provided as an argument when running the script.",
            "description": "Detailed coding problem statement"
          },
          "constraints": {
            "type": "string",
            "example": "The solution should handle errors gracefully and not crash if the file does not exist or is unreadable. Assume the file contains only text data with newlines separating each line.",
            "description": "Constraints for solving the problem"
          },
          "sampleInput": {
            "type": "string",
            "example": "./path/to/file.txt",
            "description": "Sample input for the coding problem"
          },
          "sampleOutput": {
            "type": "string",
            "example": "Total lines: 100",
            "description": "Expected sample output"
          },
          "expectedApproach": {
            "type": "string",
            "example": "Use fs.readFile() to read the file, split the content by newline characters, and count the number of elements in the resulting array. Handle errors using try-catch blocks.",
            "description": "Suggested approach to solve the problem"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the coding question"
          }
        },
        "required": [
          "title",
          "problem",
          "constraints",
          "sampleInput",
          "sampleOutput",
          "expectedApproach",
          "difficulty"
        ]
      },
      "GenerateAssessmentResponseDto": {
        "type": "object",
        "properties": {
          "mcqs": {
            "description": "List of generated MCQ questions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/McqDto"
            }
          },
          "coding": {
            "description": "List of generated coding questions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CodingQuestionDto"
            }
          }
        },
        "required": [
          "mcqs",
          "coding"
        ]
      },
      "ApiErrorResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "Gemini API key is missing"
          },
          "errors": {
            "type": "object",
            "example": null,
            "nullable": true
          },
          "details": {
            "type": "object",
            "example": null,
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-12T17:15:00.000Z"
          },
          "path": {
            "type": "string",
            "example": "/ai/generate-assessment"
          }
        },
        "required": [
          "success",
          "statusCode",
          "message",
          "errors",
          "details",
          "timestamp",
          "path"
        ]
      },
      "InterviewHistoryDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "What is virtual DOM?",
            "description": "Previously asked interview question"
          },
          "answer": {
            "type": "string",
            "example": "It is a lightweight copy of real DOM",
            "description": "Candidate answer for the question"
          }
        },
        "required": [
          "question",
          "answer"
        ]
      },
      "ProcessInterviewDto": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "example": "React",
            "description": "Interview topic or technology"
          },
          "history": {
            "description": "Previous interview questions and answers",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InterviewHistoryDto"
            }
          },
          "latestAnswer": {
            "type": "string",
            "example": "React compares changes efficiently before updating DOM.",
            "description": "Latest answer provided by the candidate"
          }
        },
        "required": [
          "topic",
          "history",
          "latestAnswer"
        ]
      },
      "EvaluationDto": {
        "type": "object",
        "properties": {
          "score": {
            "type": "number",
            "example": 3,
            "description": "Score given to the latest answer"
          },
          "confidence": {
            "type": "number",
            "example": 70,
            "description": "Confidence percentage of the evaluation"
          },
          "strengths": {
            "example": [
              "Understands basic concept of virtual DOM"
            ],
            "description": "Strong points identified in the answer",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "weaknesses": {
            "example": [
              "Lacks detail on how React optimizes updates"
            ],
            "description": "Areas where the answer needs improvement",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "score",
          "confidence",
          "strengths",
          "weaknesses"
        ]
      },
      "NextQuestionDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "How does React optimize the process of updating the real DOM when state or props change?",
            "description": "Next interview question generated for the candidate"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the next question"
          },
          "focusArea": {
            "type": "string",
            "example": "React's optimization techniques",
            "description": "Topic focus area for the next question"
          }
        },
        "required": [
          "question",
          "difficulty",
          "focusArea"
        ]
      },
      "ProcessInterviewResponseDto": {
        "type": "object",
        "properties": {
          "evaluation": {
            "$ref": "#/components/schemas/EvaluationDto"
          },
          "nextQuestion": {
            "$ref": "#/components/schemas/NextQuestionDto"
          }
        },
        "required": [
          "evaluation",
          "nextQuestion"
        ]
      }
    }
  }
}