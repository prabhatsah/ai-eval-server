{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/auth/signup": {
      "post": {
        "operationId": "AuthController_signup",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully registered"
          },
          "400": {
            "description": "Invalid input data"
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "summary": "Login user and return JWT token",
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "operationId": "AuthController_refresh",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "AuthController_logout",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": [
          "Auth"
        ]
      }
    },
    "/evaluations": {
      "post": {
        "operationId": "EvaluationController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEvaluationDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evaluation created successfully"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create a new evaluation (Manager only)",
        "tags": [
          "Evaluations"
        ]
      },
      "get": {
        "operationId": "EvaluationController_getAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "List of evaluations"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get all evaluations",
        "tags": [
          "Evaluations"
        ]
      }
    },
    "/evaluations/{id}": {
      "get": {
        "operationId": "EvaluationController_getById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "example": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Evaluation found"
          },
          "404": {
            "description": "Evaluation not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get evaluation by ID",
        "tags": [
          "Evaluations"
        ]
      }
    },
    "/attempt/start": {
      "post": {
        "operationId": "AttemptController_start",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAttemptDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attempt started successfully"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Start a new attempt",
        "tags": [
          "Attempts"
        ]
      }
    },
    "/attempt/answer": {
      "post": {
        "operationId": "AttemptController_submit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitAnswerDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Answer submitted successfully"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Submit answer for a question",
        "tags": [
          "Attempts"
        ]
      }
    },
    "/attempt/submit": {
      "post": {
        "operationId": "AttemptController_finalize",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Attempt submitted successfully"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Finalize attempt and calculate score",
        "tags": [
          "Attempts"
        ]
      }
    },
    "/ai/generate-assessment": {
      "post": {
        "operationId": "AiController_generateAssessment",
        "parameters": [
          {
            "name": "x-api-key",
            "required": false,
            "in": "header",
            "description": "API Key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateAssessmentDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assessment generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateAssessmentResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Error response structure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponseDto"
                }
              }
            }
          }
        },
        "summary": "Generate MCQ and coding assessment questions",
        "tags": [
          "Assessment"
        ]
      }
    },
    "/ai/generate-from-jd": {
      "post": {
        "description": "Parses a job description to extract structured hiring signals and generates a complete technical assessment.",
        "operationId": "AiController_generateFromJd",
        "parameters": [
          {
            "name": "x-api-key",
            "required": false,
            "in": "header",
            "description": "API Key for AI provider",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateFromJdDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assessment generated successfully from JD",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateFromJdResponseDto"
                }
              }
            }
          }
        },
        "summary": "Generate assessment from job description",
        "tags": [
          "Assessment"
        ]
      }
    }
  },
  "info": {
    "title": "AI Evaluation API",
    "description": "API documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SignupDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "test@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123"
          },
          "role": {
            "type": "string",
            "enum": [
              "MANAGER",
              "EMPLOYEE"
            ],
            "example": "MANAGER"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "role"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "test@gmail.com"
          },
          "password": {
            "type": "string",
            "example": "StrongPass123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "SectionConfigDto": {
        "type": "object",
        "properties": {
          "weight": {
            "type": "number",
            "example": 0.5,
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "weight"
        ]
      },
      "SectionsDto": {
        "type": "object",
        "properties": {
          "AI": {
            "$ref": "#/components/schemas/SectionConfigDto"
          },
          "MCQ": {
            "$ref": "#/components/schemas/SectionConfigDto"
          },
          "CODING": {
            "$ref": "#/components/schemas/SectionConfigDto"
          }
        },
        "required": [
          "AI",
          "MCQ",
          "CODING"
        ]
      },
      "CreateEvaluationDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Frontend Assessment"
          },
          "skill": {
            "type": "string",
            "example": "React"
          },
          "sections": {
            "$ref": "#/components/schemas/SectionsDto"
          },
          "passingScore": {
            "type": "number",
            "example": 60,
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": [
          "title",
          "skill",
          "sections",
          "passingScore"
        ]
      },
      "StartAttemptDto": {
        "type": "object",
        "properties": {
          "evaluationId": {
            "type": "string",
            "example": "evaluation-uuid"
          }
        },
        "required": [
          "evaluationId"
        ]
      },
      "SubmitAnswerDto": {
        "type": "object",
        "properties": {
          "attemptId": {
            "type": "string",
            "example": "attempt-uuid"
          },
          "question": {
            "type": "string",
            "example": "What is closure in JavaScript?"
          },
          "answer": {
            "type": "string",
            "example": "A closure is a function with preserved scope..."
          },
          "type": {
            "type": "string",
            "enum": [
              "MCQ",
              "CODING",
              "AI"
            ],
            "example": "AI"
          }
        },
        "required": [
          "attemptId",
          "question",
          "answer",
          "type"
        ]
      },
      "GenerateAssessmentDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "example": "Backend Engineer",
            "description": "Target role for the assessment"
          },
          "primarySkills": {
            "example": [
              "Node.js",
              "SQL",
              "REST APIs"
            ],
            "description": "Primary skills that must be covered in the assessment",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "secondarySkills": {
            "example": [
              "Docker",
              "Redis"
            ],
            "description": "Optional secondary skills",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "experienceYears": {
            "type": "number",
            "example": 3,
            "description": "Years of experience of the candidate"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the assessment",
            "enum": [
              "easy",
              "medium",
              "hard"
            ]
          },
          "mcqCount": {
            "type": "number",
            "example": 10,
            "description": "Number of MCQ questions (default = 10)"
          },
          "codingCount": {
            "type": "number",
            "example": 1,
            "description": "Number of coding questions (default = 1)"
          },
          "focusAreas": {
            "example": [
              "API design",
              "database optimization"
            ],
            "description": "Focus areas for question generation",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "role",
          "primarySkills",
          "difficulty"
        ]
      },
      "McqDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "A Node.js API intermittently returns 500 errors under load. What is the most likely cause?",
            "description": "MCQ question"
          },
          "skill": {
            "type": "string",
            "example": "Node.js",
            "description": "Skill this question belongs to"
          },
          "options": {
            "example": [
              "A) Event loop blocking due to sync code",
              "B) DNS lookup failure",
              "C) Incorrect HTTP method",
              "D) Missing environment variables"
            ],
            "description": "Available answer options",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "correctAnswer": {
            "type": "string",
            "example": "A",
            "description": "Correct answer option"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the MCQ"
          },
          "explanation": {
            "type": "string",
            "example": "Synchronous operations block the event loop, causing request handling delays and failures under load.",
            "description": "Explanation of the correct answer"
          }
        },
        "required": [
          "question",
          "skill",
          "options",
          "correctAnswer",
          "difficulty",
          "explanation"
        ]
      },
      "CodingQuestionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Build a Rate-Limited API Endpoint",
            "description": "Title of the coding problem"
          },
          "problem": {
            "type": "string",
            "example": "Design a REST API endpoint in Node.js that limits requests per user to 100 requests per minute. Exceeding requests should return HTTP 429.",
            "description": "Detailed coding problem statement"
          },
          "constraints": {
            "type": "string",
            "example": "The solution must handle concurrent users efficiently. Avoid in-memory-only solutions for scalability.",
            "description": "Constraints for solving the problem"
          },
          "sampleInput": {
            "type": "string",
            "example": "User sends 120 requests in 1 minute",
            "description": "Sample input for the coding problem"
          },
          "sampleOutput": {
            "type": "string",
            "example": "First 100 requests succeed, next 20 return 429",
            "description": "Expected sample output"
          },
          "expectedApproach": {
            "type": "string",
            "example": "Use middleware with Redis to track request counts per user and reset using expiration policies.",
            "description": "Suggested approach to solve the problem"
          },
          "difficulty": {
            "type": "string",
            "example": "medium",
            "description": "Difficulty level of the coding question"
          }
        },
        "required": [
          "title",
          "problem",
          "constraints",
          "sampleInput",
          "sampleOutput",
          "expectedApproach",
          "difficulty"
        ]
      },
      "GenerateAssessmentResponseDto": {
        "type": "object",
        "properties": {
          "mcqs": {
            "description": "List of generated MCQ questions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/McqDto"
            }
          },
          "coding": {
            "description": "List of generated coding questions",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CodingQuestionDto"
            }
          }
        },
        "required": [
          "mcqs",
          "coding"
        ]
      },
      "ApiErrorResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "Gemini API key is missing"
          },
          "errors": {
            "type": "object",
            "example": null,
            "nullable": true
          },
          "details": {
            "type": "object",
            "example": null,
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-12T17:15:00.000Z"
          },
          "path": {
            "type": "string",
            "example": "/ai/generate-assessment"
          }
        },
        "required": [
          "success",
          "statusCode",
          "message",
          "errors",
          "details",
          "timestamp",
          "path"
        ]
      },
      "GenerateFromJdDto": {
        "type": "object",
        "properties": {
          "jd": {
            "type": "string",
            "example": "We are looking for a Backend Engineer with 3+ years experience in Node.js, SQL, REST APIs. Knowledge of Docker and Redis is a plus.",
            "description": "Full job description text"
          },
          "mcqCount": {
            "type": "number",
            "example": 10,
            "description": "Optional MCQ count (default 10)"
          },
          "codingCount": {
            "type": "number",
            "example": 1,
            "description": "Optional coding question count (default 1)"
          }
        },
        "required": [
          "jd"
        ]
      },
      "ParsedJdDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "example": "Backend Engineer"
          },
          "primarySkills": {
            "example": [
              "Node.js",
              "SQL",
              "REST APIs"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "secondarySkills": {
            "example": [
              "Docker",
              "Redis"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "experienceYears": {
            "type": "number",
            "example": 3
          },
          "difficulty": {
            "type": "string",
            "example": "medium"
          },
          "mcqCount": {
            "type": "number",
            "example": 10
          },
          "codingCount": {
            "type": "number",
            "example": 1
          },
          "focusAreas": {
            "example": [
              "API design",
              "database optimization"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "role",
          "primarySkills",
          "secondarySkills",
          "experienceYears",
          "difficulty",
          "mcqCount",
          "codingCount",
          "focusAreas"
        ]
      },
      "GenerateFromJdResponseDto": {
        "type": "object",
        "properties": {
          "jd": {
            "description": "Structured JD data extracted by AI",
            "allOf": [
              {
                "$ref": "#/components/schemas/ParsedJdDto"
              }
            ]
          },
          "assessment": {
            "description": "Generated assessment based on JD",
            "allOf": [
              {
                "$ref": "#/components/schemas/GenerateAssessmentResponseDto"
              }
            ]
          }
        },
        "required": [
          "jd",
          "assessment"
        ]
      }
    }
  }
}